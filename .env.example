# LoopLink Platform - Root Environment Configuration
# Copy this file to .env and update with your values
# .env files are gitignored and should never be committed

# ===== BACKEND =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secure_postgres_password
DB_NAME=looplink

SERVER_PORT=8080
ENVIRONMENT=development

JWT_SECRET=change_this_to_a_secure_random_key_in_production

# ML Service Configuration
ML_ENABLED=false
ML_SERVICE_URL=http://localhost:8000/optimize
ML_TIMEOUT_MS=1200
ML_BLEND_WEIGHT=0.35

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ===== FRONTEND (Shipper/Admin) =====
VITE_API_URL=http://localhost:8080/api/v1
VITE_ENVIRONMENT=development

# ===== DRIVER APP =====
EXPO_PUBLIC_API_URL=http://10.236.168.104:8080/api/v1
# Note: For Android emulator: http://10.0.2.2:8080/api/v1
# For physical phone: Use your machine LAN IP

# Demo Credentials (for development only - change in production)
VITE_DEMO_EMAIL=driver1@looplink.com
VITE_DEMO_PASSWORD=changeme
